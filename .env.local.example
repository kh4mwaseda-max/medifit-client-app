# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# Trainer auth
TRAINER_PASSWORD=your-secure-password
TRAINER_SESSION_TOKEN=your-random-token-32chars
TRAINER_ID=your-trainer-uuid-from-supabase

# App URL
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# LINE公式アカウント（Messaging API）
LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token
LINE_CHANNEL_SECRET=your-channel-secret
# Webhook URL（LINE Developers コンソールに登録）: https://your-app.vercel.app/api/line/webhook

# Billing（falseのままローンチ。trueにするだけで課金フロー有効化）
NEXT_PUBLIC_BILLING_ENABLED=false
