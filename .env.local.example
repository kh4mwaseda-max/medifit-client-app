# ===================================================
# Client Fit 環境変数テンプレート
# コピーして .env.local にリネームして使ってください
# cp .env.local.example .env.local
# ===================================================

# ── Supabase ──────────────────────────────────────
# 取得場所: https://supabase.com → プロジェクト → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://cpjskwdsznfupicsqbpy.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Anthropic Claude API ──────────────────────────
# 取得場所: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ── トレーナー認証 ───────────────────────────────
# TRAINER_PASSWORDは任意のパスワード
# TRAINER_SESSION_TOKENはランダム32文字以上（openssl rand -hex 32 で生成可）
# TRAINER_IDはSupabase → Table Editor → trainers テーブルのUUID
TRAINER_PASSWORD=
TRAINER_SESSION_TOKEN=
TRAINER_ID=3072f02e-d70e-4e3a-a67b-55e88981351c

# ── アプリURL ────────────────────────────────────
# ローカル開発中: http://localhost:3000
# 本番: https://your-domain.com （ドメイン取得後に設定）
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── LINE Messaging API ───────────────────────────
# 取得場所: https://developers.line.biz → チャネル → Messaging API設定
# WebhookURLの登録先: https://your-domain.com/api/line/webhook
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
# 公式LINE友達追加リンク（LP・招待画面で使用）
# 取得場所: LINE Official Account Manager → 友だち追加QR
NEXT_PUBLIC_LINE_FRIEND_URL=

# ── Vercel Cron ──────────────────────────────────
# デイリーサマリー配信の認証トークン（openssl rand -hex 32 で生成）
# 未設定だと /api/cron/daily-summary が 401 を返す
CRON_SECRET=

# ── Stripe 課金（NEXT_PUBLIC_BILLING_ENABLED=true の場合のみ必須） ─
# 取得場所: https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# ── 課金フラグ ───────────────────────────────────
# falseのままローンチ。trueにするだけで課金フロー有効化
NEXT_PUBLIC_BILLING_ENABLED=false

# ── 開発・デバッグ用（本番では設定しない） ────────
# ALLOW_RESET=true で /api/reset が有効化（DB全削除）
ALLOW_RESET=
# 単独テスト時に本人LINEへ通知可否を切替
SOLO_TEST_MODE=
