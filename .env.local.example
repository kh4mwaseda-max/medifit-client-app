# ===================================================
# Client Fit 環境変数テンプレート
# コピーして .env.local にリネームして使ってください
# cp .env.local.example .env.local
# ===================================================

# ── Supabase ──────────────────────────────────────
# 取得場所: https://supabase.com → プロジェクト → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://cpjskwdsznfupicsqbpy.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Anthropic Claude API ──────────────────────────
# 取得場所: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ── トレーナー認証 ───────────────────────────────
# TRAINER_PASSWORDは任意のパスワード
# TRAINER_SESSION_TOKENはランダム32文字以上（openssl rand -hex 32 で生成可）
# TRAINER_IDはSupabase → Table Editor → trainers テーブルのUUID
TRAINER_PASSWORD=
TRAINER_SESSION_TOKEN=
TRAINER_ID=3072f02e-d70e-4e3a-a67b-55e88981351c

# ── アプリURL ────────────────────────────────────
# ローカル開発中: http://localhost:3000
# 本番: https://your-domain.com （ドメイン取得後に設定）
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── LINE Messaging API ───────────────────────────
# 取得場所: https://developers.line.biz → チャネル → Messaging API設定
# WebhookURLの登録先: https://your-domain.com/api/line/webhook
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# ── 課金フラグ ───────────────────────────────────
# falseのままローンチ。trueにするだけで課金フロー有効化
NEXT_PUBLIC_BILLING_ENABLED=false
